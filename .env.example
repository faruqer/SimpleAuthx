# Server
NODE_ENV=development
PORT=3000

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=simpleauthx
DB_USER=postgres
DB_PASSWORD=your_password_here

# JWT
JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRES_IN=7d

# OAuth / OIDC
OAUTH_ISSUER=http://localhost:3000
OAUTH_ACCESS_TOKEN_EXPIRES_IN_SECONDS=3600
OAUTH_AUTH_CODE_EXPIRES_IN_SECONDS=300

# RS256 signing keys (PEM, use \n for line breaks)
OAUTH_PRIVATE_KEY=
OAUTH_PUBLIC_KEY=
OAUTH_KEY_ID=

# Security
ENFORCE_HTTPS=false
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_OAUTH_MAX_REQUESTS=60
